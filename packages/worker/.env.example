# ── Fuel Finder API credentials ──────────────────────────────────────
FUEL_FINDER_CLIENT_ID=your-client-id
FUEL_FINDER_CLIENT_SECRET=your-client-secret

# ── API endpoint ─────────────────────────────────────────────────────
# Controls which Fuel Finder API the worker talks to.
#   "test"                          → staging (stg.fuel-finder.ics.gov.uk)
#   omitted / anything else         → production (fuel-finder.service.gov.uk)
#   a full URL (http:// or https://)→ custom endpoint / reverse proxy
#
# Example: point at a UK reverse proxy to avoid geo-IP blocks:
#   USE_API=https://my-uk-proxy.example.com/api
USE_API=

# ── Extra request headers (optional) ────────────────────────────────
# A JSON object of additional headers to send with every Fuel Finder
# API request (including OAuth calls).  Useful for authenticating with
# a reverse proxy.
#
# Example:
#   FUEL_FINDER_EXTRA_HEADERS={"X-Proxy-Key": "some-secret"}
FUEL_FINDER_EXTRA_HEADERS=

# ── OpenRouter (optional, used for LLM station-name cleaning) ───────
OPENROUTER_API_KEY=
