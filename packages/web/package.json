{
	"name": "@petrol-baby/web",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "cross-env NODE_ENV=development vite dev",
		"fetch-font": "node scripts/fetch-font.js",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "pnpm run types && svelte-kit sync || echo ''",
		"check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"types": "wrangler types",
		"lint": "eslint ."
	},
	"dependencies": {
		"@petrol-baby/worker": "workspace:*"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"bun-types": "^1.3.12",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"wrangler": "catalog:wrangler"
	}
}
